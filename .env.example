# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Option A: Supabase (or any provider that gives a full connection string) ---
# Get this from Supabase: Project Settings -> Database -> Connection string
# (use the "Transaction pooler" URI for typical app usage). Example shape:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Option B: discrete fields (e.g. Neon, self-hosted Postgres) ---
# Only used if DATABASE_URL is not set.
SQL_HOST=your-db-host.example.com
SQL_PORT=5432
SQL_DB_NAME=your_database_name
SQL_USER=your_db_user
SQL_PASSWORD=your_db_password

# Set to "false" only for a local Postgres instance without SSL.
SQL_SSL=true

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_generated_random_secret

NODE_ENV=development
PORT=3000
